# Copy this file to `.env` and fill in your real litres.ru credentials.
# `.env` is gitignored -- it never gets committed.
#
# This is optional: without it, you can still log in through the web UI's
# login form (or through the login_to_litres MCP tool) and the session will
# be remembered from then on. Setting these just lets the app/MCP server
# bootstrap a session automatically on first run, with no manual login step.

LITRES_LOGIN=you@example.com
LITRES_PASSWORD=your-litres-password

# Everything below is optional -- sensible defaults are used if unset.

# Web UI port (host is always 127.0.0.1 -- not configurable, by design).
# LITRES_APP_PORT=8420

# Where the MCP server's download_book tool saves files.
# LITRES_DOWNLOAD_DIR=/Users/you/Downloads/litres-library

# Where the browser session (cookies) is cached between runs.
# LITRES_SESSION_FILE=/absolute/path/to/.litres_session.json

# Per-file download timeout in milliseconds. Whole-audiobook bundles can be
# ~2GB; raise this on a slow connection, lower it to fail faster on a stuck
# transfer.
# LITRES_DOWNLOAD_TIMEOUT_MS=300000

# Set to 0 to watch the login flow in a real (non-headless) Chromium
# window -- useful for debugging a login/selector problem.
# LITRES_HEADLESS=1

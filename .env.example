# Copy this file to `.env` and fill in your real litres.ru credentials.
# `.env` is gitignored -- it never gets committed.
#
# This is optional: without it, you can still log in through the web UI's
# login form (or through the login_to_litres MCP tool) and the session will
# be remembered from then on. Setting these just lets the app/MCP server
# bootstrap a session automatically on first run, with no manual login step.

LITRES_LOGIN=you@example.com
LITRES_PASSWORD=your-litres-password

# Copy this file to `.env` and fill in your real litres.ru credentials.
# `.env` is gitignored -- it never gets committed.
#
# These credentials are used by the MCP server ONLY. The MCP server is
# headless (no login form), so it bootstraps a first session from these on
# first run. The web app does NOT use them: you log in through its login
# page, and the session is saved (cookies + OS keychain) and reused from
# then on. So if you only use the web app, you can leave these unset.

LITRES_LOGIN=you@example.com
LITRES_PASSWORD=your-litres-password

# Everything below is optional -- sensible defaults are used if unset.

# Web UI port (host is always 127.0.0.1 -- not configurable, by design).
# LITRES_APP_PORT=8420

# Where the MCP server's download_book tool saves files.
# LITRES_DOWNLOAD_DIR=/Users/you/Downloads/litres-library

# Where the browser session (cookies) is cached between runs.
# LITRES_SESSION_FILE=/absolute/path/to/.litres_session.json

# Per-file download timeout in milliseconds. Whole-audiobook bundles can be
# ~2GB; raise this on a slow connection, lower it to fail faster on a stuck
# transfer.
# LITRES_DOWNLOAD_TIMEOUT_MS=300000

# Set to 0 to watch the login flow in a real (non-headless) Chromium
# window -- useful for debugging a login/selector problem.
# LITRES_HEADLESS=1

# Logging verbosity for the app's own log lines (login, library listing,
# download progress, ...). One of DEBUG/INFO/WARNING/ERROR.
# LITRES_LOG_LEVEL=INFO

# Where the library listing and per-book file-listing cache is stored (see
# app/cache.py) -- this is what lets a page reload or app restart skip
# re-querying litres.ru for data it already has.
# LITRES_CACHE_FILE=/absolute/path/to/.litres_cache.json

# How long (seconds) the cached library listing is considered fresh before
# it's re-fetched. Buying something new won't show up until this expires,
# or you click the UI's Refresh button.
# LITRES_LIBRARY_CACHE_TTL=900

# How long (seconds) a book's cached file listing (used for size display
# and downloads) is considered fresh. Long-lived by default -- a purchased
# book's available formats essentially never change.
# LITRES_FILES_CACHE_TTL=604800
